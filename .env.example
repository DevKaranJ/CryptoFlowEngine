# Environment Configuration Template
# Copy this file to .env and fill in your values

# ==================== Exchange API ====================
# Binance API (only needed for real trading, not required for paper trading)
# Get your API keys from: https://www.binance.com/en/api
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Testnet (use testnet for testing)
BINANCE_TESTNET=true

# ==================== Database ====================
# Database URL (SQLite by default)
DATABASE_URL=sqlite:///data/cryptobot.db

# ==================== Dashboard ====================
# Dashboard host and port
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# ==================== Logging ====================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== Trading ====================
# Initial paper trading balance
INITIAL_BALANCE=10000

# Risk management
DEFAULT_RISK_PERCENT=1.0
MIN_RISK_REWARD=1.5

